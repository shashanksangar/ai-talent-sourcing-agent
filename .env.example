# Environment Configuration for AI Talent Sourcing Agent

# Anthropic Claude API (via Tesla Bottlerocket / Vertex AI)
ANTHROPIC_VERTEX_BASE_URL=your_vertex_endpoint
ANTHROPIC_AUTH_TOKEN=your_auth_token
ANTHROPIC_VERTEX_PROJECT_ID=your_project_id

# GitHub API Configuration
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# LinkedIn API Configuration (requires OAuth setup)
# See linkedin_client.py for setup instructions
LINKEDIN_TOKEN=your_linkedin_oauth_token

# ArXiv Configuration (no token required - public API)
# Optional: Email for ArXiv user-agent
ARXIV_EMAIL=your_email@example.com

# API Rate Limiting
RATE_LIMIT_DELAY=1.0
MAX_RETRIES=3

# Database or storage
# DATABASE_URL=sqlite:///sourcing.db