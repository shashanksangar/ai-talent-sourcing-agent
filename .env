# Environment Configuration for AI Talent Sourcing Agent
# Tesla Recruiting - Bottlerocket Vertex AI Integration

# Claude Code Configuration
CLAUDE_CODE_SKIP_VERTEX_AUTH=1
CLAUDE_CODE_USE_VERTEX=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Anthropic Claude Models
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5

# Anthropic Claude API (via Tesla Bottlerocket / Vertex AI)
ANTHROPIC_VERTEX_BASE_URL=https://inference.bottlerocket.tesla.com/models/gcp-vertex-recruiting/v1
ANTHROPIC_AUTH_TOKEN=a46d718007a25ae546bc213764f840ea056f2a1384c1425451e7da8321e5d747
ANTHROPIC_VERTEX_PROJECT_ID=bottle-rocket-recruiting

# GCP Configuration
CLOUD_ML_REGION=global

# GitHub API Configuration
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=

# LinkedIn API Configuration (requires OAuth setup)
# See linkedin_client.py for setup instructions
LINKEDIN_TOKEN=

# ArXiv Configuration (no token required - public API)
